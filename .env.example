# Email (IMAP) credentials
IMAP_HOST=imap.your-provider.com
IMAP_PORT=993
EMAIL_ADDRESS=your-email@example.com
EMAIL_PASSWORD=your-email-password

# Email (SMTP) credentials
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=465

# WordPress admin credentials
WP_ADMIN_URL=https://your-site.com/wp-admin
WP_ADMIN_USER=admin-username
WP_ADMIN_PASSWORD=admin-password

# New user default password
NEW_USER_PASSWORD=1234

# How often to check email (seconds)
CHECK_INTERVAL=300
